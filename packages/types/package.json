{
  "name": "@vibedcoder/invespro-types",
  "version": "0.1.1",
  "description": "Types and Zod schemas for investment profiling and allocation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibedcoder/invespro.git",
    "directory": "packages/types"
  },
  "homepage": "https://github.com/vibedcoder/invespro/tree/main/packages/types#readme",
  "bugs": {
    "url": "https://github.com/vibedcoder/invespro/issues"
  },
  "keywords": [
    "investment",
    "risk-profile",
    "asset-allocation",
    "zod",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc -b --emitDeclarationOnly",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@invespro/eslint-config": "workspace:*",
    "@invespro/tsconfig": "workspace:*",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
