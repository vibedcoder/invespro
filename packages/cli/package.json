{
  "name": "@vibedcoder/invespro-cli",
  "version": "0.1.0",
  "description": "CLI for investment risk profiling",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "invespro": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsx --tsconfig tsconfig.dev.json src/index.ts",
    "typecheck": "tsc -b --emitDeclarationOnly",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@vibedcoder/invespro-core": "workspace:*",
    "@vibedcoder/invespro-types": "workspace:*",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@invespro/eslint-config": "workspace:*",
    "@invespro/tsconfig": "workspace:*",
    "@types/node": "^25.9.3",
    "tsdown": "^0.22.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
