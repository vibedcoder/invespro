{
  "name": "@vibedcoder/invespro-cli",
  "version": "0.1.0",
  "description": "CLI for investment risk profiling",
  "license": "MIT",
  "type": "module",
  "bin": {
    "invespro": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@vibedcoder/invespro-core": "workspace:*",
    "@vibedcoder/invespro-types": "workspace:*",
    "citty": "^0.2.2"
  },
  "devDependencies": {
    "@invespro/eslint-config": "workspace:*",
    "@invespro/tsconfig": "workspace:*",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4"
  }
}
